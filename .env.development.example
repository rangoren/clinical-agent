APP_ENV=development

ANTHROPIC_API_KEY=your_shared_or_dev_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=clinical_assistant_development

APP_BASE_URL=https://your-dev-domain.example.com
APP_TIMEZONE=Asia/Jerusalem

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-dev-domain.example.com/calendar/google/callback

ENABLE_EXTERNAL_SIDE_EFFECTS=false
ENABLE_GOOGLE_CALENDAR_INTEGRATION=false
ALLOW_NON_PROD_PROD_DB=false


R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_dev_r2_bucket_name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
