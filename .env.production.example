APP_ENV=production

ANTHROPIC_API_KEY=your_production_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=clinical_assistant

APP_BASE_URL=https://your-production-domain.example.com
APP_TIMEZONE=Asia/Jerusalem

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-production-domain.example.com/calendar/google/callback

ENABLE_EXTERNAL_SIDE_EFFECTS=true
ENABLE_GOOGLE_CALENDAR_INTEGRATION=true
ALLOW_NON_PROD_PROD_DB=false

R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_production_r2_bucket_name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
